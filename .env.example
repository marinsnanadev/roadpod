# SMTP usado pela function api/send-mail.js (Nodemailer)
# Funciona com Gmail (App Password), Outlook, Zoho, ou qualquer provedor SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_app_password

# Para quem as mensagens do formulário devem ser enviadas.
# Se omitido, cai no SMTP_USER.
CONTACT_TO_EMAIL=roadpodglifos@gmail.com

# Domínio autorizado a chamar a function (evita que outros sites usem seu SMTP).
# Em desenvolvimento local pode deixar '*' ou 'http://localhost:3000'.
CORS_ALLOWED_ORIGIN=https://roadpodglifos.com
